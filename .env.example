# Copy to .env and fill in values for local development.
# Generate SESSION_SECRET: python -c "import secrets; print(secrets.token_urlsafe(48))"

SESSION_SECRET=
APP_ENV=development

# Database — Railway injects DATABASE_URL automatically when Postgres is attached.
# Local dev: omit DATABASE_URL to use SQLite at app/data/app.db
# DATABASE_URL=postgresql://user:pass@host:5432/railway

# Upload storage — Railway Volume mount (see RAILWAY_STORAGE_SETUP.md)
# Production default: /data/uploads (volume mounted at /data)
# Local dev override:
CREDANTA_UPLOAD_DIR=app/uploads

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

APP_BASE_URL=
OPENAI_API_KEY=
