# Copy to .env and fill in values for local development.
# Generate SESSION_SECRET: python -c "import secrets; print(secrets.token_urlsafe(48))"

SESSION_SECRET=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID ends with .apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET starts with GOCSPX- (NOT the same as the client ID)
# Authorized redirect URIs:
#   Local:      http://localhost:5000/auth/google/callback
#   Production: https://travel-nurse-credentials-production.up.railway.app/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional but recommended on Railway — used for OAuth callback diagnostics
APP_BASE_URL=

OPENAI_API_KEY=
