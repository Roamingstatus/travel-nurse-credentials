modules = ["python-3.12", "web", "nodejs-20", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["stripe:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tesseract", "tk", "zlib"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python run.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["python", "run.py"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[userenv]

[userenv.shared]
STRIPE_PRICE_PREMIUM_MONTHLY = "price_1TbRDlPWALiH5IrqY2966DAF"
STRIPE_PRICE_PREMIUM_YEARLY = "price_1TbRDlPWALiH5IrqOs0wAvHQ"
STRIPE_PRICE_PREMIUM_PLUS_MONTHLY = "price_1TbRDmPWALiH5IrqgCU4LXRu"
STRIPE_PRICE_PREMIUM_PLUS_YEARLY = "price_1TbRDnPWALiH5IrqVOVRylQb"

